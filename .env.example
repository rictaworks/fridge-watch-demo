# fridge-watch-demo 環境変数テンプレート
# コピーして .env を作成する（.env は gitignore 済み。値は commit しない）
# 時刻は JST、エンコードは UTF-8 で統一する。

# --- 共通 ---
APP_ENV=development            # development | production
TZ=Asia/Tokyo

# --- フロント (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# --- バックエンド (Rails) ---
RAILS_ENV=development
# RAILS_MASTER_KEY=            # 本番のみ環境変数で渡す。ここに実値を書かない
DATABASE_URL=sqlite3:db/development.sqlite3   # デモ版は SQLite

# --- OCR (FastAPI) ---
OCR_SERVICE_URL=http://localhost:8000

# --- 認証 (本番: Google ログイン。開発は認証済みへ分岐) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- ESP32 (Wi-Fi / HTTP。送信先は許可リストで制限) ---
ESP32_BASE_URL=http://192.168.4.1

# --- 日次リセット ---
DAILY_RESET_CRON=0 3 * * *     # JST 03:00

# --- デモ版コア実装(src/ の Node.js フルスタック) ---
PORT=3000
FW_DB_PATH=data/fridge.db      # :memory: 可
FW_ESP32_MODE=virtual          # virtual | http | off
# NODE_ENV=production           # 本番相当で Cookie を Secure に分岐
