{
  "name": "fridge-watch-demo",
  "version": "0.1.0-demo",
  "private": true,
  "description": "スマート冷蔵庫管理デモ版(食材残量・賞味期限の自動検知)",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -r config dist/config && cp -r web dist/web",
    "start": "node dist/server/main.js",
    "dev": "ts-node server/main.ts",
    "seed": "ts-node lib/db/seed.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
